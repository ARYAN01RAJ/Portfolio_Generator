<!DOCTYPE html>
<html>
<head>
    <title>Clean Portfolio</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="container">

    <div class="header">
        <h1><%= about.name %></h1>
        <p><%= about.bio %></p>
    </div>

    <div class="section">
        <h2>Projects</h2>

        <% projects.forEach(p => { %>
            <div class="card">
                <h3><%= p.name %></h3>
                <p><%= p.language %> • ⭐ <%= p.star_count %></p>
                <a href="<%= p.url %>">View</a>
            </div>
        <% }) %>
    </div>

    <div class="section">
        <h2>Skills</h2>
        <div>
            <% skills.forEach(s => { %>
                <span class="tag"><%= s.language %></span>
            <% }) %>
        </div>
    </div>

</div>

</body>
</html>