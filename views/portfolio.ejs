<!DOCTYPE html>
<html>
<head>
    <title>Portfolio</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="container">

    <!-- HEADER -->
    <div class="header">
        <img src="<%= about.avatar %>" class="avatar" />
        <h1><%= about.name %></h1>
        <p><%= about.bio %></p>
        <a href="<%= about.profile_url %>" target="_blank">GitHub Profile</a>
    </div>

    <!-- STATS -->
    <div class="section">
        <h2>Stats</h2>
        <div class="card">
            <p>Repos: <%= stats.totalRepos %></p>
            <p>Followers: <%= stats.followers %></p>
            <p>Following: <%= stats.following %></p>
        </div>
    </div>

    <!-- PROJECTS -->
    <div class="section">
        <h2>Projects</h2>

        <% projects.forEach(project => { %>
            <div class="card">
                <h3><%= project.name %></h3>
                <p>⭐ <%= project.star_count %> | 🛠 <%= project.language %></p>
                <a href="<%= project.url %>" target="_blank">View Project</a>
            </div>
        <% }) %>

    </div>

    <!-- SKILLS -->
    <div class="section">
        <h2>Skills</h2>

        <% skills.forEach(skill => { %>
            <div class="card">
                <strong><%= skill.language %></strong>
                <p>Used in <%= skill.count %> projects</p>
            </div>
        <% }) %>

    </div>

</div>

</body>
</html>