<!DOCTYPE html>
<html>
<head>
    <title>Dark Portfolio</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body style="background:#0f172a; color:white;">

<div class="container">

    <div class="header">
        <img src="<%= about.avatar %>" class="avatar"/>
        <h1><%= about.name %></h1>
        <p><%= about.bio %></p>
    </div>

    <div class="section">
        <h2>Projects</h2>

        <% projects.forEach(p => { %>
            <div class="card" style="background:#1e293b; color:white;">
                <h3><%= p.name %></h3>
                <p>⭐ <%= p.star_count %> • <%= p.language %></p>
                <a href="<%= p.url %>" style="color:#38bdf8;">View</a>
            </div>
        <% }) %>

    </div>

</div>

</body>
</html>